{
	"name": "tomato-clock",
	"version": "1.0.0",
	"type": "module",
	"description": "番茄钟桌面应用",
	"main": "dist-electron/main.js",
	"scripts": {
		"dev": "vp dev",
		"build": "tsgo && vp build && npm run build:electron",
		"build:electron": "node scripts/build-electron.mjs",
		"electron:dev": "concurrently \"vp dev\" \"electron .\"",
		"electron:build": "cross-env ELECTRON_BUILDER_FORCE_LOCAL_TOOLCHAIN=1 npm run build && electron-builder",
		"test": "vp test",
		"test:watch": "vp test --watch",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"@radix-ui/react-progress": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-router-dom": "^7.15.0",
		"sql.js": "^1.14.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^22.0.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260506.1",
		"@vitejs/plugin-react": "^6.0.1",
		"7zip-bin": "^5.2.0",
		"concurrently": "^8.2.2",
		"cross-env": "^10.1.0",
		"electron": "^42.0.0",
		"electron-builder": "^26.8.1",
		"esbuild": "^0.28.0",
		"jsdom": "^29.1.1",
		"playwright": "^1.59.1",
		"png-to-ico": "^3.0.1",
		"sharp": "^0.34.5",
		"tailwindcss": "^4.2.4",
		"vite-plus": "^0.1.20"
	}
}
