{
  "name": "tomato-clock",
  "version": "1.0.0",
  "type": "module",
  "description": "番茄钟桌面应用",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vp dev",
    "build": "tsgo && vp build && npm run build:electron",
    "build:electron": "node scripts/build-electron.mjs",
    "electron:dev": "concurrently \"vp dev\" \"electron .\"",
    "electron:build": "npm run build && electron-builder",
    "test": "vp test",
    "test:watch": "vp test --watch",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@typescript/native-preview": "^7.0.0-dev.20260506.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.15.0",
    "sql.js": "^1.10.0",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.24.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "tailwindcss": "npm:tailwindcss@4.2.4",
    "typescript": "npm:@typescript/native-preview@*",
    "vite-plus": "*"
  }
}
